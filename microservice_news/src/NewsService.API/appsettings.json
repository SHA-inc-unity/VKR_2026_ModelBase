{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },

  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  "Kafka": {
    "BootstrapServers": "redpanda:29092",
    "NewsEventsTopic": "events.news.v1"
  },

  "News": {
    "CryptoPanic": {
      "AuthToken": "",
      "PollIntervalSeconds": 300,
      "PostsUrl": "https://cryptopanic.com/api/v1/posts/",
      "RssUrl": "https://cryptopanic.com/news/rss/",
      "Enabled": true
    }
  },

  "AllowedHosts": "*"
}
