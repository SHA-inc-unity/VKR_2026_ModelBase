# Account Service — Environment Variables
# Copy this file to .env and fill in the values

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=account_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here

# Full connection string (used by the API container)
DATABASE_URL=Host=postgres;Port=5432;Database=account_service;Username=postgres;Password=your_strong_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be >= 32 characters, cryptographically random in production
JWT_SECRET_KEY=change-me-to-a-long-random-secret-key-32c

JWT_ISSUER=account-service
JWT_AUDIENCE=exchange-app
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# ── BCrypt ────────────────────────────────────────────────────────────────────
BCRYPT_WORK_FACTOR=12

# ── Redis (optional) ──────────────────────────────────────────────────────────
# Leave empty to disable Redis (NullTokenCacheService will be used)
REDIS_URL=

# ── Internal API ──────────────────────────────────────────────────────────────
# Secret key for inter-service communication (X-Internal-Api-Key header)
INTERNAL_API_KEY=change-me-internal-api-key

# ── Admin bootstrap account ──────────────────────────────────────────────────
# Optional. When all three values are set, Account Service creates or promotes
# this login-only admin account during DB migration. Public registration always
# creates a regular `user`; it never creates `admin` accounts.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=

# ── Host port and bind address ────────────────────────────────────────────────
ACCOUNT_API_PORT=7510
# local: leave empty (binds to 0.0.0.0)
# split deployment: set to backend private interface IP if you want to restrict the published port
ACCOUNT_BIND_ADDR=
