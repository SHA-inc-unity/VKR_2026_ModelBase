{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=account_service_dev;Username=postgres;Password=postgres"
  },

  "Jwt": {
    "SecretKey": "dev-secret-key-change-in-production-must-be-32-chars-minimum",
    "Issuer": "account-service",
    "Audience": "exchange-app",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },

  "Password": {
    "WorkFactor": 4
  },

  "InternalApi": {
    "ApiKey": "dev-internal-api-key"
  }
}
