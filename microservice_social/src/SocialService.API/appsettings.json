{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },

  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  "Jwt": {
    "SecretKey": "",
    "Issuer": "account-service",
    "Audience": "exchange-app"
  },

  "Kafka": {
    "BootstrapServers": "redpanda:29092",
    "SocialEventsTopic": "events.social.v1"
  },

  "AccountService": {
    "BaseUrl": "http://account-api:5000",
    "InternalApiKey": ""
  },

  "InternalApi": {
    "ApiKey": ""
  },

  "AllowedHosts": "*"
}
