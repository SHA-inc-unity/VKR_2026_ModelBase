{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },

  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  "Jwt": {
    "SecretKey": "",
    "Issuer": "account-service",
    "Audience": "exchange-app"
  },

  "Kafka": {
    "BootstrapServers": "redpanda:29092",
    "SocialEventsTopic": "events.social.v1",
    "NewsEventsTopic": "events.news.v1",
    "GroupId": "notification-service"
  },

  "SocialService": {
    "BaseUrl": "http://social_service_api:5000",
    "InternalApiKey": ""
  },

  "Gateway": {
    "BaseUrl": "http://exchange-gateway:5020"
  },

  "PriceWatcher": {
    "PollIntervalSeconds": 300,
    "Enabled": true
  },

  "AlertWatcher": {
    "PollIntervalSeconds": 60,
    "Enabled": true
  },

  "Push": {
    "VapidPublicKey": "BCUdvlH58kkkWyQyCVT7SxSDcQYbkS2XW8QLuELAaN1bnTHrDYrTmCLNh1ldxkB6MbUphogzbGzo_i6Xw8VHYcg",
    "VapidPrivateKey": "",
    "VapidSubject": "mailto:admin@sha-trade.tech"
  },

  "AllowedHosts": "*"
}
