NOTIF_BIND_ADDR=0.0.0.0
NOTIF_API_PORT=7550
DATABASE_URL=Host=postgres;Port=5432;Database=notification_service;Username=postgres;Password=postgres;Pooling=true;MinPoolSize=1;MaxPoolSize=25
POSTGRES_DB=notification_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
JWT_SECRET_KEY=change-me-to-a-long-random-secret-key-32c
JWT_ISSUER=account-service
JWT_AUDIENCE=exchange-app
KAFKA_BOOTSTRAP_SERVERS=redpanda:29092
KAFKA_SOCIAL_TOPIC=events.social.v1
KAFKA_NEWS_TOPIC=events.news.v1
KAFKA_GROUP_ID=notification-service
SOCIAL_BASE_URL=http://social_service_api:5000
INTERNAL_API_KEY=change-me-internal-api-key
GATEWAY_BASE_URL=http://exchange-gateway:5020
PRICE_WATCHER_POLL_SECONDS=300
PRICE_WATCHER_ENABLED=true
# Price-alert evaluator (user-defined target alerts). Poll cadence is floored at 30s.
ALERT_WATCHER_POLL_SECONDS=60
ALERT_WATCHER_ENABLED=true
# Web Push (VAPID). The public key has a safe default baked into compose; the
# PRIVATE key is a secret and MUST be set here (host-only) to enable push delivery.
# Leave empty to keep push disabled (the service logs a single warning and skips it).
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:admin@sha-trade.tech
