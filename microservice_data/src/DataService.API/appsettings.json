{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "DataService": {
    "Postgres": {
      "Host": "postgres",
      "Port": 5432,
      "Database": "crypt_date",
      "User": "postgres",
      "Password": "postgres"
    },
    "Kafka": {
      "BootstrapServers": "redpanda:29092"
    },
    "Minio": {
      "Endpoint": "http://minio:9000",
      "AccessKey": "modelline",
      "SecretKey": "modelline_secret",
      "Bucket": "modelline-blobs",
      "Region": "us-east-1"
    },
    "Api": {
      "Host": "0.0.0.0",
      "Port": 8100
    }
  }
}
