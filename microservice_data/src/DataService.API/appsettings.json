{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "DataService": {
    "Postgres": {
      "Host": "postgres",
      "Port": 5432,
      "Database": "crypt_date",
      "User": "postgres",
      "Password": "postgres"
    },
    "Kafka": {
      "BootstrapServers": "redpanda:29092"
    },
    "Minio": {
      "Endpoint": "http://minio:9000",
      "AccessKey": "modelline",
      "SecretKey": "modelline_secret",
      "Bucket": "modelline-blobs",
      "Region": "us-east-1"
    },
    "Api": {
      "Host": "0.0.0.0",
      "Port": 8100
    },
    "MarketWatch": {
      "Enabled": true,
      "BootstrapIntervalSeconds": 15,
      "FlushIntervalMs": 1000,
      "ProgressIntervalSeconds": 10,
      "BybitSymbolsPerSubscription": 50,
      "KrakenSymbolsPerSubscription": 200,
      "Symbols": [ "BTCUSDT", "ETHUSDT", "SOLUSDT", "BNBUSDT", "XRPUSDT", "ADAUSDT", "DOGEUSDT", "AVAXUSDT", "DOTUSDT", "LINKUSDT", "MATICUSDT", "UNIUSDT", "ATOMUSDT", "LTCUSDT", "NEARUSDT", "TONUSDT", "SUIUSDT", "APTUSDT" ],
      "Exchanges": [ "bybit", "binance", "kraken" ],
      "Timeframes": [ "1m", "3m", "5m", "15m", "30m", "60m", "120m", "240m", "360m", "720m", "1d" ]
    }
  }
}
