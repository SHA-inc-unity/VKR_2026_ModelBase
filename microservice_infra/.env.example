MINIO_ROOT_USER=modelline
MINIO_ROOT_PASSWORD=modelline_secret
# local/full stack: localhost
# split deployment (noadmin): must be backend WG IP — see microservice_infra/VPN_CONTAINERIZED.md
REDPANDA_EXTERNAL_HOST=localhost
REDPANDA_EXTERNAL_PORT=9092
REDPANDA_ADMIN_PORT=9644
REDPANDA_CONSOLE_PORT=8080
# Bind address for Redpanda external ports 9092 and 9644.
# local: leave empty (binds to 0.0.0.0 — all interfaces)
# split deployment: set to backend WG IP (e.g. 10.44.0.1) to restrict to WG interface only
REDPANDA_BIND_ADDR=
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Bind address for MinIO external port 9000.
# local: leave empty (binds to 0.0.0.0)
# split deployment: set to backend WG IP (e.g. 10.44.0.1)
MINIO_BIND_ADDR=
NGINX_PORT=8501

# Public HTTPS port for the remote admin facade exposed by infra-nginx.
ADMIN_BACKEND_PORT=8443
# Directory with tls.crt and tls.key for the 8443 TLS server.
# If the directory is empty, nginx-cert-init generates a self-signed pair
# here on first `docker compose up -d`.
ADMIN_BACKEND_CERTS_DIR=./nginx/certs

# ── Containerized VPN (WireGuard over WebSocket/TCP) — split deployment ──
# Legacy fallback only. Set to 1 to explicitly enable deprecated VPN/WStunnel
# transport for split deployment. Default split path uses ADMIN_BACKEND_PORT +
# HTTPS admin facade and does not start VPN services.
ENABLE_CONTAINERIZED_VPN=0
# Set VPN_SERVER_URL only when ENABLE_CONTAINERIZED_VPN=1 and you intentionally
# use the legacy containerized VPN fallback. The launcher puts this value in
# join-token metadata so the admin host can start wstunnel-client.
VPN_SERVER_URL=
# Internal UDP port the WireGuard server listens on locally behind wstunnel.
# In default ws mode this UDP port does not need to be public; open VPN_WS_PORT/tcp.
VPN_SERVER_PORT=51820
VPN_TRANSPORT=ws
# Public TCP port for WebSocket transport. Default 8443 avoids privileged-port
# binding and leaves backend-host 443 free for reverse proxies or HTTPS.
VPN_WS_PORT=8443
VPN_WS_PATH=modelline-wg
VPN_CLIENT_LOCAL_PORT=51820
