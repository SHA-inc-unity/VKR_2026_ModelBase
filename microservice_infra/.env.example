MINIO_ROOT_USER=modelline
MINIO_ROOT_PASSWORD=modelline_secret
# local/full stack: localhost
# split deployment (noadmin): must be backend WG IP — see microservice_infra/WG_WSTUNNEL.md
REDPANDA_EXTERNAL_HOST=localhost
REDPANDA_EXTERNAL_PORT=9092
REDPANDA_ADMIN_PORT=9644
REDPANDA_CONSOLE_PORT=8080
# Bind address for Redpanda external ports 9092 and 9644.
# local: leave empty (binds to 0.0.0.0 — all interfaces)
# split deployment: set to backend WG IP (e.g. 10.44.0.1) to restrict to WG interface only
REDPANDA_BIND_ADDR=
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Bind address for MinIO external port 9000.
# local: leave empty (binds to 0.0.0.0)
# split deployment: set to backend WG IP (e.g. 10.44.0.1)
MINIO_BIND_ADDR=
NGINX_PORT=8501
