KAFKA_BOOTSTRAP_SERVERS=redpanda:29092
REDPANDA_ADMIN_URL=redpanda:9644
ACCOUNT_URL=account_service_api:5000
GATEWAY_URL=exchange-gateway:5020
REDIS_URL=redis://redis:6379/0
MINIO_URL=minio:9000

# ── Split-deployment (admin-host ↔ backend-host, no VPN) ─────────────────────
# When ADMIN_BACKEND_BASE_URL is set, the admin connects to all backend
# services through a single HTTPS endpoint on the backend host instead of
# directly over Kafka, Redpanda, MinIO, etc.
#
# Set up:
#   1. Generate a shared secret: openssl rand -hex 32
#   2. Copy to ADMIN_BACKEND_SHARED_TOKEN here and ADMIN_SHARED_TOKEN on the
#      backend (gateway) side.
#   3. The backend host must expose port 8443 (or the port in the URL) via
#      nginx (see microservice_infra/nginx/nginx.conf for the server block).
#
# Leave both blank to use direct-Kafka / single-host mode.
ADMIN_BACKEND_BASE_URL=
ADMIN_BACKEND_SHARED_TOKEN=

# Used by admin-online in split deployment.
# Launcher convenience field. `start/restart ... onlyadmin` can ask for one
# backend host/IP and derive the rest of ONLINE_* from it.
ONLINE_BACKEND_HOST=

# If admin runs on a different host than backend, these values MUST point to
# the backend host (public IP, WG IP, or private DNS). Leaving them empty means
# docker-compose defaults will be used, and those localhost defaults only work
# when admin-online runs on the same machine as the published backend ports.
# Example:
# ONLINE_KAFKA_BOOTSTRAP_SERVERS=10.44.0.1:9092
# ONLINE_REDPANDA_ADMIN_URL=10.44.0.1:9644
# ONLINE_ACCOUNT_URL=10.44.0.1:7510
# ONLINE_GATEWAY_URL=10.44.0.1:7520
# ONLINE_MINIO_URL=10.44.0.1:9000
ONLINE_KAFKA_BOOTSTRAP_SERVERS=
ONLINE_REDPANDA_ADMIN_URL=
ONLINE_ACCOUNT_URL=
ONLINE_GATEWAY_URL=
ONLINE_REDIS_URL=
ONLINE_MINIO_URL=

ADMIN_PORT=443

# ── Legacy VPN transport (deprecated; use ADMIN_BACKEND_BASE_URL instead) ────
# These vars are kept for backward compatibility. They are ignored when
# ADMIN_BACKEND_BASE_URL is set.
VPN_SERVER_URL=
VPN_SERVER_PORT=51820
VPN_WS_PORT=8443
VPN_WS_PATH=modelline-wg
VPN_CLIENT_LOCAL_PORT=51820
