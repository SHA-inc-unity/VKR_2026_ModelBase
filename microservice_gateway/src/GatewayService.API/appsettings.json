{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  },

  "DownstreamServices": {
    "Account": {
      "BaseUrl": "http://account-service:5000",
      "Enabled": true
    },
    "Portfolio": {
      "BaseUrl": "http://portfolio-service:5001",
      "Enabled": false
    },
    "Market": {
      "BaseUrl": "http://market-service:5002",
      "Enabled": false
    },
    "News": {
      "BaseUrl": "http://news-service:5003",
      "Enabled": false
    },
    "Notifications": {
      "BaseUrl": "http://notification-service:5004",
      "Enabled": false
    }
  },

  "Jwt": {
    "SecretKey": "",
    "Issuer": "account-service",
    "Audience": "exchange-app"
  },

  "FeatureFlags": {
    "Portfolio": false,
    "Market": false,
    "News": false,
    "Notifications": false
  },

  "Resilience": {
    "TimeoutSeconds": 5,
    "RetryCount": 2,
    "CircuitBreakerFailureThreshold": 5,
    "CircuitBreakerDurationSeconds": 30
  },

  "AllowedHosts": "*"
}
