{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  },

  "Kafka": {
    "BootstrapServers": "redpanda:29092"
  },

  "Admin": {
    "DefaultTimeoutSeconds": 15,
    "LongTimeoutSeconds": 300
  },

  "Cors": {
    "AllowAnyOrigin": false,
    "AllowedOrigins": [ "https://sha-trade.tech", "https://www.sha-trade.tech" ],
    "PreflightMaxAgeSeconds": 600
  },

  "DownstreamServices": {
    "Portfolio": {
      "BaseUrl": "http://portfolio-service:5001",
      "Enabled": false
    },
    "Market": {
      "BaseUrl": "http://market-service:5002",
      "Enabled": false
    },
    "News": {
      "BaseUrl": "http://news_service_api:5000",
      "Enabled": true
    },
    "Notifications": {
      "BaseUrl": "http://notification_service_api:5000",
      "Enabled": true
    },
    "Social": {
      "BaseUrl": "http://social_service_api:5000",
      "Enabled": true
    }
  },

  "Jwt": {
    "SecretKey": "",
    "Issuer": "account-service",
    "Audience": "exchange-app"
  },

  "FeatureFlags": {
    "Portfolio": false,
    "Market": false,
    "News": false,
    "Notifications": false
  },

  "Resilience": {
    "TimeoutSeconds": 5,
    "RetryCount": 2,
    "CircuitBreakerFailureThreshold": 5,
    "CircuitBreakerDurationSeconds": 30
  },

  "AllowedHosts": "*",

  "Redis": {
    "Configuration": "redis:6379"
  },

  "Market": {
    "BybitBaseUrl": "https://api.bybit.com",
    "CoinGeckoBaseUrl": "https://api.coingecko.com/api/v3",
    "CoinGeckoApiKey": "",
    "CoinMetadataCacheTtlSeconds": 21600,
    "WindowChangeCacheTtlSeconds": 120,
    "FearGreedBaseUrl": "https://api.alternative.me",
    "DefaultSymbol": "BTCUSDT",
    "DefaultTimeframe": "5m",
    "DefaultCandleCount": 200,
    "SymbolsCacheTtlSeconds": 3600,
    "ConfigCacheTtlSeconds": 3600,
    "ChartCacheTtlHeavySeconds": 30,
    "ChartCacheTtlMediumSeconds": 120,
    "ChartCacheTtlLightSeconds": 300,
    "SnapshotCacheTtlSeconds": 30,
    "GlobalOverviewCacheTtlSeconds": 180,
    "KafkaTimeoutSeconds": 30,
    "IngestKafkaTimeoutSeconds": 300,
    "IngestRetryAfterMs": 5000,
    "IngestLockTtlSeconds": 360,
    "FullCoverageThreshold": 0.99,
    "IngestWindowMultiplier": 3,
    "IngestErrorCooldownSeconds": 5,
    "QueueTotalConcurrency": 10,
    "QueueHeavyConcurrency": 3,
    "QueueMaxWaitSeconds": 5,
    "ChartInflightWaitSeconds": 45,
    "ChartInflightPollMs": 750
  }
}
