# JWT (must match Account Service exactly)
JWT_SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ISSUER=account-service
JWT_AUDIENCE=exchange-app

# Downstream service URLs
ACCOUNT_SERVICE_URL=http://localhost:7510
ACCOUNT_DB_CONNECTION=Host=localhost;Port=5432;Database=exchange_accounts;Username=postgres;Password=postgres

# Internal gateway security key (for inter-service calls if needed)
INTERNAL_GATEWAY_KEY=change-me-gateway-internal-key

# ── Host port and bind address ────────────────────────────────────────────────
GATEWAY_API_PORT=7520
# local: leave empty (binds to 0.0.0.0)
# split deployment: set to backend private interface IP if you want to restrict the published port
GATEWAY_BIND_ADDR=
