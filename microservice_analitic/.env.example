# ─── PostgreSQL ───────────────────────────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGDATABASE=crypt_date
PGUSER=postgres
PGPASSWORD=your_password_here

# ─── Redis (опционально; если не задан — используется SQLite) ─────────────────
# REDIS_URL=redis://localhost:6379/0

# ─── FastAPI ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ─── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_AUTOSTART=false
SCHEDULER_TIMEZONE=UTC
# Пример: переобучать BTCUSDT 60m каждый день в 03:00 UTC
# SCHEDULER_JOBS=[{"symbol":"BTCUSDT","timeframe":"60m","cron":"0 3 * * *","use_gpu":false,"target_col":"target_return_1"}]

# ─── MLflow (опционально) ─────────────────────────────────────────────────────
# MLFLOW_TRACKING_URI=http://localhost:5000
